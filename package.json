{
  "name": "janzheng",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev",
    "build": "astro build && deno run --allow-read --allow-write ./scripts/patch-deno-entry.ts",
    "preview": "deno run --allow-net --allow-read --allow-env --allow-import ./dist/server/entry.mjs",
    "build-preview": "npm run build && npm run preview",
    "format": "deno fmt && prettier --write .",
    "prod": "npm run build && deno deploy --org yawnxyz --app janzheng --prod ./dist",
    "test": "npm run build && deno deploy --org yawnxyz --app janzheng ./dist",
    "astro": "astro"
  },
  "dependencies": {
    "svelte-jsoneditor": "^3.5.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/svelte": "^8.0.5",
    "@astrojs/tailwind": "^6.0.2",
    "@deno/astro-adapter": "^0.4.0",
    "@fontsource-variable/gelasio": "^5.1.0",
    "@fontsource-variable/nunito": "^5.1.0",
    "@fontsource/frank-ruhl-libre": "^5.1.0",
    "@fontsource/inter": "^5.1.0",
    "@fontsource/nanum-myeongjo": "^5.1.0",
    "@fontsource/permanent-marker": "^5.1.0",
    "@fontsource/shrikhand": "^5.1.0",
    "@iconify/svelte": "^4.0.2",
    "@internationalized/date": "^3.5.5",
    "@yawnxyz/sheetlog": "^0.0.17",
    "astro": "^6.1.9",
    "autoprefixer": "^10.4.20",
    "bits-ui": "^0.21.15",
    "chrono-node": "^2.7.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk-sv": "^0.0.18",
    "cssnano": "^7.0.6",
    "dayjs": "^1.11.13",
    "markdown-it": "^14.1.0",
    "markdown-it-attrs": "^4.2.0",
    "marked": "^14.1.2",
    "postcss": "^8.5.1",
    "postcss-discard-comments": "^7.0.3",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.0",
    "prism": "^4.1.2",
    "prism-solarized-dark": "^1.0.1",
    "radix-icons-svelte": "^1.2.1",
    "sass-embedded": "^1.78.0",
    "scss": "^0.2.4",
    "svelte": "^5.15.0",
    "svelte-immer-store": "^1.0.2",
    "svelte-persisted-store": "^0.12.0",
    "svelte-preprocess": "^6.0.3",
    "svelte-radix": "^1.1.1",
    "tailwind-merge": "^2.5.2",
    "tailwind-variants": "^0.2.1",
    "tailwindcss": "^3.4.10",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.3",
    "vite": "^6.4.2"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
