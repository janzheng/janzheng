{
  "name": "janzheng",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev --host",
    "start-notes": "Notes: astro dev will not be able to import any deno modules. Use `yarn deno` instead, which runs astro AND does deno imports, with live sync; ",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deno": "astro build && deno run --allow-net --allow-read --allow-env --watch ./dist/server/entry.mjs",
    "astro:watch": "nodemon --watch src --ext js,ts,jsx,tsx,astro,svelte,vue --exec \"astro build\"",
    "format": "deno fmt && prettier --write .",
    "prod": "npm run build && deployctl deploy --prod --project=janzheng --no-static --include=./dist ./dist/server/entry.mjs",
    "astro": "astro",
    "deno-dnt": "cd src/deno/; deno run -A ./build.ts"
  },
  "dependencies": {
    "svelte-jsoneditor": "^2.3.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.7.0",
    "@astrojs/mdx": "^3.1.7",
    "@astrojs/react": "^3.6.2",
    "@astrojs/svelte": "^5.7.0",
    "@astrojs/tailwind": "^5.1.0",
    "@deno/astro-adapter": "^0.1.3",
    "@fontsource-variable/gelasio": "^5.1.0",
    "@fontsource-variable/nunito": "^5.1.0",
    "@fontsource/frank-ruhl-libre": "^5.1.0",
    "@fontsource/inter": "^5.1.0",
    "@fontsource/nanum-myeongjo": "^5.1.0",
    "@fontsource/permanent-marker": "^5.1.0",
    "@fontsource/shrikhand": "^5.1.0",
    "@iconify/svelte": "^4.0.2",
    "@internationalized/date": "^3.5.5",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@yawnxyz/sheetlog": "^0.0.17",
    "astro": "^5.18.1",
    "autoprefixer": "^10.4.20",
    "bits-ui": "^0.21.15",
    "chrono-node": "^2.7.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk-sv": "^0.0.18",
    "cssnano": "^7.0.6",
    "dayjs": "^1.11.13",
    "lucide-react": "^0.445.0",
    "markdown-it": "^14.1.0",
    "markdown-it-attrs": "^4.2.0",
    "marked": "^14.1.2",
    "postcss-discard-comments": "^7.0.3",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.0",
    "prism": "^4.1.2",
    "prism-solarized-dark": "^1.0.1",
    "radix-icons-svelte": "^1.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass-embedded": "^1.78.0",
    "scss": "^0.2.4",
    "svelte": "^4.2.19",
    "svelte-immer-store": "^1.0.2",
    "svelte-masonry": "^0.1.4",
    "svelte-persisted-store": "^0.11.0",
    "svelte-radix": "^1.1.1",
    "tailwind-merge": "^2.5.2",
    "tailwind-variants": "^0.2.1",
    "tailwindcss": "^3.4.10",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.3"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
