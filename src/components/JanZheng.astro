---
/*
  JanZheng.astro — Landing page component

  Fetches blogalog data from coverflow-v3 API and renders the profile,
  explorations, and notes sections.

  Cache busting (see ../../labspace/.brief/cache-layers.md for the full stack):
    ?refresh=true  — the canonical bust. Propagates through all cache layers.
    /reload        — user-friendly redirect that appends ?refresh=true.

  Back-compat (accepted, not documented in new places):
    noCache=true / nocache=true  — aliases for refresh=true
    mode=live                    — runtime flag, NOT a full bust

  Local dev (janzheng + coverflow-v3 running locally):
    mode=local     — Fetch from localhost:9999 (always bypasses caches)
    1. Start coverflow-v3:  cd coverflow-v3 && deno task serve
    2. Start janzheng:      cd janzheng && npm run dev
    3. Visit:               http://localhost:4321/?mode=local

  Production:
    - Default:        https://janzheng.com/
    - Force refresh:  https://janzheng.com/?refresh=true (or /reload)

  API Endpoints:
    - Local:  http://localhost:9999/janzheng
    - Prod:   https://coverflow.labspace.ai/janzheng
*/

import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/700.css";

import "@fontsource/nanum-myeongjo/400.css";
import "@fontsource/nanum-myeongjo/700.css";

import { marked } from "@components/blogalog/utils/markdownit.js";
import { cachedFetch } from "@lib/cache";
import BlogalogProfile from "@components/blogalog/BlogalogProfile.svelte";

import Explorations from "@components/Explorations.svelte";
import Notes from "@components/Notes.svelte";

// Get URL parameters and set up pathData
const { url } = Astro;
const urlParams = new URLSearchParams(url.search);
const refresh = urlParams.get("refresh") === "true";
const noCache = urlParams.get("noCache") === "true";

let pathData = {
  name: "janzheng",
  isLive:
    urlParams.get("mode")?.includes("live") ||
    Astro.locals?.pathData?.mode ||
    "",
  isLocal:
    urlParams.get("mode")?.includes("local") ||
    Astro.locals?.pathData?.local ||
    "",
};

// Local mode always bypasses caches for faster dev iteration
const shouldRefresh = noCache || refresh || !!pathData.isLocal;

// Helper function to generate the correct URL based on environment
function getUrl(path) {
  const base = pathData?.isLocal
    ? `http://localhost:9999/${path}`
    : `https://coverflow.labspace.ai/${path}`;
  const params = new URLSearchParams();
  if (pathData?.isLive) params.set("mode", "live");
  if (shouldRefresh) params.set("noCache", "true");
  const qs = params.toString();
  return qs ? `${base}?${qs}` : base;
}

const apiUrl = getUrl(pathData.name);

let blogalogData = {};
try {
  blogalogData = await cachedFetch(apiUrl, {
    refresh: shouldRefresh,
    fetchOptions: {
      headers: {
        Accept: "application/json",
        "Content-Type": "application/json; charset=utf-8",
      },
    },
  });
  /* 
    process / render markdown / etc
  */
  blogalogData.meta = {
    ...blogalogData.meta,
    longDescription:
      blogalogData.meta?.longDescription &&
      marked(blogalogData.meta.longDescription),
    shortDescription:
      blogalogData.meta?.shortDescription &&
      marked(blogalogData.meta.shortDescription),
    location: blogalogData.meta?.location && marked(blogalogData.meta.location),
  };
} catch (error) {
  console.error(
    `"Error fetching or parsing blogalog data: [${getUrl(pathData.name)}]`,
    error
  );
}

// Short browser + edge cache so Notion edits propagate within ~1 min + SWR
// window keeps repeat visits snappy. See labspace/.brief/cache-layers.md.
// EXCEPT on bust requests: no-store so repeat busts always re-fetch.
Astro.response.headers.set(
  'Cache-Control',
  shouldRefresh
    ? 'no-store, must-revalidate'
    : 'public, max-age=60, stale-while-revalidate=3600'
);
---

<div class="JanZheng | container mx-auto pt-12">
  <BlogalogProfile {blogalogData} client:load="svelte" />
  <Explorations {blogalogData} client:load="svelte" />
  <Notes {blogalogData} client:load="svelte" />
</div>
