---
/*
  [postPath].astro — Individual blog post page

  Fetches blogalog data from coverflow-v3 API and renders a single post
  matched by the URL path (e.g., /svelte-masonry).

  URL Query Parameters:
    mode=local     — Fetch from localhost:9999 (always bypasses caches)
    refresh=true   — Bust both local (Astro cachedFetch) and remote (Smallstore) caches
    noCache=true   — Same as refresh; busts both caches

  Local Development (sacramento + coverflow-v3 running locally):
    1. Start coverflow-v3:  cd coverflow-v3 && deno task serve
    2. Start sacramento:    cd sacramento && npm run dev
    3. Visit a post:        http://localhost:4321/svelte-masonry?mode=local
       (always fresh — caches are automatically bypassed in local mode)

  Production (fetches from coverflow.labspace.ai):
    - Default:              http://localhost:4321/svelte-masonry
    - Force refresh:        http://localhost:4321/svelte-masonry?refresh=true

  API Endpoints:
    - Local:  http://localhost:9999/janzheng
    - Prod:   https://coverflow.labspace.ai/janzheng
*/

import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/700.css';

import '@fontsource/nanum-myeongjo/400.css';
import '@fontsource/nanum-myeongjo/700.css';

import { marked } from 'marked';
import { cachedFetch } from '@lib/cache';
import Layout from '@layouts/Layout.astro';
import BlogalogPostPage from '@components/blogalog/BlogalogPostPage.svelte';
import BlogalogFooter from '@components/blogalog/BlogalogFooter.svelte';

// custom posts
import MoreWithLess from '@components/projects/moreWithLess/MoreWithLess.astro';

const { url: astroUrl } = Astro;
const urlParams = new URLSearchParams(astroUrl.search);
const isLocal = urlParams.get("mode")?.includes("local");
const refresh = urlParams.get("refresh") === "true";
const noCache = urlParams.get("noCache") === "true";

// Local mode always bypasses caches for faster dev iteration
const shouldRefresh = noCache || refresh || !!isLocal;

// Build API URL with query params
const base = isLocal
  ? "http://localhost:9999/janzheng"
  : "https://coverflow.labspace.ai/janzheng";
const params = new URLSearchParams();
if (isLocal) params.set("mode", "local");
if (shouldRefresh) params.set("noCache", "true");
const qs = params.toString();
const url = qs ? `${base}?${qs}` : base;

const { postPath } = Astro.params;
let blogalogData = {}, currentPost;
try {
  blogalogData = await cachedFetch(url, {
    refresh: shouldRefresh,
    fetchOptions: {
      headers: {
        'Accept': 'application/json',
        'Content-Type': 'application/json; charset=utf-8'
      }
    },
  });
  currentPost = blogalogData.pages?.find(item => item.path === postPath) || null;

  if (!currentPost) {
    console.log('rewrite to 404');
    return Astro.rewrite('/404');
  }

} catch (error) {
  console.error(`Error fetching or parsing blogalog data: [${url}]`, error);
}

---
<Layout title={currentPost?.name}>
  <div class="JanZheng | Article | ">
    {currentPost && (
      <BlogalogPostPage {blogalogData} {currentPost} client:load="svelte">
        {postPath === "more-with-less" && (
          <MoreWithLess/>
        )}
      </BlogalogPostPage>
      <BlogalogFooter {blogalogData} client:load="svelte" />
    )}
  </div>
</Layout>
