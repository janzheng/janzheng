---

console.log('requesturl:', Astro.request.url);
const url = new URL(Astro.request.url);
const sessionToken = url.searchParams.get('session_token');

if (!sessionToken) {
  return new Response("Invalid session token", { status: 400 });
}

// Set the session cookie
const response = new Response(null, {
  status: 302, // Redirect status
  headers: {
    'Set-Cookie': `session_token=${sessionToken}; HttpOnly; Secure; Path=/; Max-Age=3600`, // 1 hour expiration
    'Location': '/dashboard' // Redirect to dashboard after setting the cookie
  }
});

return response;
---