---
const AUTH_ORIGIN = "https://auth.labspace.ai";
const ORIGIN = "https://yawnxyz-newwebsite.web.val.run";

const redirectUri = `${ORIGIN}/auth/github/callback`; // URL to return to after GitHub login
const authServiceUrl = `${AUTH_ORIGIN}/auth/github?redirect_uri=${redirectUri}`;

// Redirect to AuthService for GitHub login
return Astro.redirect(authServiceUrl);
---