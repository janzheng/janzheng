---
const AUTH_ORIGIN = 'https://auth.labspace.ai';
const ORIGIN = 'https://janzheng.com';
---

<!DOCTYPE html>
<html>
<head>
  <title>Login</title>
</head>
<body>
  <h1>Login</h1>
  <form method="POST" action={`${AUTH_ORIGIN}/auth/login`}>
    <input type="hidden" name="redirect_uri" value={`${ORIGIN}/auth/callback`} />
    <label for="username">Username:</label>
    <input type="text" name="username" required />
    <label for="password">Password:</label>
    <input type="password" name="password" required />
    <button type="submit">Login</button>
  </form>

  <h2>Or sign in with:</h2>
  <a href={`${AUTH_ORIGIN}/auth/github?redirect_uri=${ORIGIN}/auth/github/callback`}>GitHub</a><br/>
  <a href={`${AUTH_ORIGIN}/auth/google?redirect_uri=${ORIGIN}/auth/google/callback`}>Google</a>
</body>
</html>